  </regressionable_path>
  <coverage>STATEMENT_BRANCH</coverage>
 </source>
 <source>
  <regressionable_path>
   <base>SourceRoot</base>
   <subpath>source_a.c</subpath>
  </regressionable_path>
  <coverage>STATEMENT_BRANCH</coverage>
 </source>
 <source>
