ENVIRO.NEW
ENVIRO.NAME: ENV_UNIT
ENVIRO.BASE_DIRECTORY: BASE_DIR=$(WORKING_DIR)
ENVIRO.STUB_BY_FUNCTION: foo
ENVIRO.WHITE_BOX: NO
ENVIRO.VCDB_FILENAME: 
ENVIRO.VCDB_CMD_VERB: 
ENVIRO.COVERAGE_TYPE: None
ENVIRO.LIBRARY_STUBS:  
ENVIRO.STUB: ALL_BY_PROTOTYPE
ENVIRO.COMPILER: CC
ENVIRO.TYPE_HANDLED_DIRS_ALLOWED: 
ENVIRO.SEARCH_LIST: $(BASE_DIR)
ENVIRO.END
